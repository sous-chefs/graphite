---
extends: default
rules:
  line-length:
    max: 256
    level: warning
  truthy:
    allowed-values: ['true', 'false', 'on']
  document-start:
    present: true
  braces:
    forbid: false
    min-spaces-inside: 0
    max-spaces-inside: 1
    min-spaces-inside-empty: -1
    max-spaces-inside-empty: -1
  comments:
    min-spaces-from-content: 1
